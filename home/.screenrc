startup_message off
defflow on
defscrollback 20000
autodetach on
altscreen on

#activity "Activity on %n"
activity ""
defmonitor on

backtick 13 4 4 ${HOME}/.local/bin/sys_info cpu
backtick 14 4 4 ${HOME}/.local/bin/sys_info pmem

caption always "%{= gk}%-Lw%{= kg}  %n%f %t  %{-}%+Lw %= %{= gk} %H (%S) %{-}%{= ck} %13` %{-}%{= yk} %14` %{-}"

shelltitle "$ |tab"

bindkey ^[[2H prev
bindkey ^[[2F next

bindkey ^[OQ screen # F2
bindkey ^[OR prev # F3
bindkey ^[OS next # F4
bindkey ^[[17~ detach # F6
bindkey ^[[18~ copy #F7
