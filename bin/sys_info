#!/usr/bin/env bash
# Print a single short stat for screen's caption backticks.
# Usage: sys_info <cpu|pmem>

case "$(uname -s)" in
  Darwin)
    case "$1" in
      cpu)
        # "CPU usage: N.NN% user, N.NN% sys, N.NN% idle" — busy = 100 - idle.
        top -l 1 -n 0 | awk '/CPU usage/ {gsub("%",""); printf "%.1f%%\n", 100 - $7}'
        ;;
      pmem)
        # PhysMem: <used> used (..., ... compressor), <unused> unused.
        # Values may be suffixed M, G, K — normalise to MB before dividing.
        top -l 1 -n 0 | awk '
          function mb(v,   u, n) {
            u = substr(v, length(v));
            n = substr(v, 1, length(v)-1) + 0;
            if (u == "G") return n * 1024;
            if (u == "K") return n / 1024;
            return n;
          }
          /PhysMem/ {
            used = mb($2);
            unused = mb($(NF-1));
            printf "%.1f%%\n", used/(used+unused)*100;
          }'
        ;;
    esac
    ;;
  Linux)
    case "$1" in
      cpu)
        read -r _ a b c d _ < /proc/stat; t1=$((a+b+c+d)); i1=$d
        sleep 0.2
        read -r _ a b c d _ < /proc/stat; t2=$((a+b+c+d)); i2=$d
        awk -v t1="$t1" -v t2="$t2" -v i1="$i1" -v i2="$i2" \
          'BEGIN { dt=t2-t1; if (dt<=0) dt=1; printf "%.1f%%\n", (1-(i2-i1)/dt)*100 }'
        ;;
      pmem)
        awk '/MemTotal:/{t=$2} /MemAvailable:/{a=$2} END{printf "%.1f%%\n", (t-a)/t*100}' /proc/meminfo
        ;;
    esac
    ;;
esac
